{
  "name": "@inficon/graphs",
  "version": "1.2.0",
  "type": "module",
  "main": "dist/lib/graphs.umd.js",
  "module": "dist/lib/graphs.es.js",
  "types": "dist/lib/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/lib/graphs.es.js",
      "require": "./dist/lib/graphs.umd.js"
    }
  },
  "files": [
    "dist/lib"
  ],
  "publishConfig": {
    "registry": "https://isaplus.pkgs.visualstudio.com/_packaging/InficonNugets/npm/registry/"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:lib": "tsc --noEmit && vite build --config vite.config.lib.ts",
    "build:nuget": "npm run build:lib && nuget.exe pack graphs.nuspec && node -e \"const v=require('./package.json').version;require('child_process').execSync('nuget.exe push Inficon.Graphs.'+v+'.nupkg -Source InficonNugets -ApiKey AzureDevOps -NonInteractive',{stdio:'inherit'})\"",
    "build:npm": "npm run build:lib && npm publish",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "jsdom": "^29.1.1",
    "typescript": "~5.9.3",
    "vite": "8.0.5",
    "vite-plugin-dts": "^5.0.0",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@react-pdf/renderer": "^4.5.1",
    "d3": "^7.9.0"
  }
}
